# Definitional proc to organize widgets for parameters.
proc init_gui { IPINST } {
  ipgui::add_param $IPINST -name "Component_Name"
  #Adding Page
  set Page_0 [ipgui::add_page $IPINST -name "Page 0"]
  ipgui::add_param $IPINST -name "correlation_length" -parent ${Page_0}


}

proc update_PARAM_VALUE.C_S_AXI_ADDR_WIDTH { PARAM_VALUE.C_S_AXI_ADDR_WIDTH PARAM_VALUE.correlation_length } {
	# Procedure called to update C_S_AXI_ADDR_WIDTH when any of the dependent parameters in the arguments change
	
	set C_S_AXI_ADDR_WIDTH ${PARAM_VALUE.C_S_AXI_ADDR_WIDTH}
	set correlation_length ${PARAM_VALUE.correlation_length}
	set values(correlation_length) [get_property value $correlation_length]
	set_property value [gen_USERPARAMETER_C_S_AXI_ADDR_WIDTH_VALUE $values(correlation_length)] $C_S_AXI_ADDR_WIDTH
}

